{
    "name": "ejosterberg/opensalestax",
    "description": "PHP SDK for the OpenSalesTax engine — open-source US sales tax calculation API.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["sales-tax", "opensalestax", "tax", "api", "sdk"],
    "homepage": "https://github.com/ejosterberg/opensalestax-php",
    "authors": [
        {"name": "Eric Osterberg", "email": "ejosterberg@gmail.com"}
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.8",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "autoload": {
        "psr-4": {"OpenSalesTax\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"OpenSalesTax\\Tests\\": "tests/"}
    },
    "scripts": {
        "test": "phpunit --testsuite=unit",
        "test-live": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint-fix": "php-cs-fixer fix",
        "stan": "phpstan analyse --no-progress"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
